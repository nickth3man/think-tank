# OpenRouter API Key for all LLM chat models (Researcher, Skeptic, Visionary, Synthesizer)
# Get yours at: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-...

# OpenAI API Key used strictly for OpenAIEmbeddings (vector database)
OPENAI_API_KEY=sk-...

# Optional: OpenRouter App Attribution
OPENROUTER_APP_URL=https://github.com/your-org/think-tank
OPENROUTER_APP_TITLE="Think Tank"

# Optional: Path to ChromaDB persistence directory (defaults to ./chroma_db)
CHROMA_DB_PATH=./chroma_db
